{
  "name": "carto",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/cart-edge",
    "apps/cart-screen",
    "packages/shared"
  ],
  "scripts": {
    "dev:edge": "npm run dev -w @carto/cart-edge",
    "dev:cli": "npm run dev:cli -w @carto/cart-edge",
    "cart:cli": "npm run dev:cli",
    "dev:screen": "npm run dev -w @carto/cart-screen",
    "dev": "npm run dev:edge",
    "map:convert": "node tools/convert-ros-map.mjs",
    "build:shared": "npm run build -w @carto/shared",
    "build:edge": "npm run build -w @carto/cart-edge",
    "build": "npm run build:shared && npm run build:edge",
    "typecheck": "npm run typecheck -w @carto/shared && npm run typecheck -w @carto/cart-edge && npm run typecheck -w @carto/cart-screen",
    "lint": "npm run lint --workspaces"
  },
  "engines": {
    "node": ">=20"
  }
}
